{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "WordSmith Scan Report",
  "type": "object",
  "required": ["target", "timestamp", "technologies", "paths"],
  "properties": {
    "target": {
      "type": "string",
      "description": "The target URL that was scanned"
    },
    "session": {
      "type": ["string", "null"],
      "description": "Name of the session used during scanning"
    },
    "timestamp": {
      "type": "string",
      "description": "ISO 8601 timestamp of when the scan was performed"
    },
    "technologies": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "confidence", "source"],
        "properties": {
          "name": { "type": "string" },
          "confidence": { "type": "string", "enum": ["low", "medium", "high"] },
          "source": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "paths": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["value", "source", "confidence"],
        "properties": {
          "value": { "type": "string" },
          "source": {
            "type": "string",
            "enum": ["tech_db", "js_scrape", "crawl", "header", "robots", "sitemap"]
          },
          "confidence": { "type": "string", "enum": ["low", "medium", "high"] },
          "technology": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
